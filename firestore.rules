rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      // Allow signed-in users to look up friend profiles by social_id.
      allow read: if isSignedIn();
      allow write: if isOwner(uid);

      match /learning_state/{stateId} {
        allow read, write: if isOwner(uid);
      }

      match /postponed_words/{topicId} {
        allow read, write: if isOwner(uid);
      }
    }

    match /user_profiles/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /user_learning_state/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /user_postponed_words/{uid}/topics/{topicId} {
      allow read, write: if isOwner(uid);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
